# Application runtime. Copy this file to .env and never commit the populated file.
APP_ENV=staging
APP_DEBUG=false
APP_URL=https://www.example.com
APP_BASE_PATH=/iaslab-projects
APP_CLEAN_URLS=true
APP_TIMEZONE=Europe/Rome
APP_SESSION_NAME=iaslab_projects_staging
APP_VERSION=12.0.0-staging
APP_LOG_PATH=storage/logs/application.log

# Authentication policy
SESSION_IDLE_TIMEOUT=1800
SESSION_ABSOLUTE_TIMEOUT=28800
PASSWORD_MIN_LENGTH=12

# MySQL credentials supplied by the hosting control panel
DB_HOST=localhost
DB_PORT=3306
DB_NAME=iaslab_projects
DB_USER=iaslab_projects
DB_PASSWORD=replace-with-a-strong-database-password

# Local Docker Compose build settings; ignored by the PHP application.
PHP_VERSION=8.3
APP_PORT=8080
PHPMYADMIN_PORT=8081
DB_PORT_FORWARD=3306
MYSQL_DATABASE=research_project_manager
MYSQL_USER=app
MYSQL_PASSWORD=choose-a-local-password
MYSQL_ROOT_PASSWORD=choose-a-local-root-password
